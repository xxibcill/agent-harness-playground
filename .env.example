# Legacy prototype configuration
ANTHROPIC_AUTH_TOKEN="replace-me"
ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
API_TIMEOUT_MS="3000000"
ANTHROPIC_MODEL="your_provider_model"

# Agent harness runtime
AGENT_HARNESS_DATABASE_URL="postgresql://agent_harness:agent_harness@127.0.0.1:5432/agent_harness"
AGENT_HARNESS_APP_NAME="agent-harness"
AGENT_HARNESS_OTEL_EXPORTER_OTLP_ENDPOINT="http://127.0.0.1:4318"

# API security
# Format: <token>=<role>,<token>=<role>
AGENT_HARNESS_API_TOKENS="viewer-token=viewer,operator-token=operator,admin-token=admin"
AGENT_HARNESS_CORS_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"

# Worker controls
AGENT_HARNESS_WORKER_ID="worker-local"
AGENT_HARNESS_WORKER_POLL_SECONDS="1.0"
AGENT_HARNESS_WORKER_LEASE_SECONDS="30"
AGENT_HARNESS_WORKER_LEASE_REFRESH_SECONDS="10.0"
AGENT_HARNESS_WORKER_RETRY_BACKOFF_SECONDS="5"
AGENT_HARNESS_WORKER_METRICS_PORT="9101"

# Web operator console
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000"
# Only use a browser token for local or single-operator environments.
NEXT_PUBLIC_API_TOKEN="operator-token"
